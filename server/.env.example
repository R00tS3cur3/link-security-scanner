# Server Configuration
PORT=5000
NODE_ENV=development

# VirusTotal API
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Database
DB_PATH=../database/scanner.db

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Cache
CACHE_TTL=86400

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100
